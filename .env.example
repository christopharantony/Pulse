# Public (client-exposed) — see src/lib/env.ts
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=

# Server-only — see src/lib/env.server.ts. The app fails fast at startup if any are missing.
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=pulse_dev

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=30d
REMEMBER_ME_REFRESH_EXPIRES=30d
EMAIL_VERIFICATION_TOKEN_EXPIRES=24h
PASSWORD_RESET_TOKEN_EXPIRES=1h
RATE_LIMIT_WINDOW=15m

APP_URL=http://localhost:3000

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="Pulse <noreply@yourdomain.com>"
